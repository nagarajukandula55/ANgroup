{
  "name": "an-group-social-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone Windows app for managing ANgroup social channels, AI content generation, avatars, and auto-pilot posting. Talks to the deployed ANgroup API over HTTPS.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"npm:electron:wait\"",
    "electron:wait": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && electron .",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "build:win": "npm run build && electron-builder --win",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-store": "^8.2.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "in.angroup.socialdesktop",
    "productName": "ANgroup Social",
    "files": ["dist/**", "dist-electron/**"],
    "win": {
      "target": "nsis"
    }
  }
}
